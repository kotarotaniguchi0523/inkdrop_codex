{
  "name": "inkdrop-codex",
  "version": "0.1.0",
  "description": "Codex-powered inline editing and next edit predictions for Inkdrop",
  "private": true,
  "main": "./lib/index.cjs",
  "type": "module",
  "engines": {
    "inkdrop": "^6.0.0"
  },
  "styleSheets": [
    "inkdrop-codex.css"
  ],
  "keymaps": [
    "inkdrop-codex.json"
  ],
  "menus": [
    "inkdrop-codex.json"
  ],
  "configSchema": {
    "predictionMode": {
      "title": "Next edit prediction",
      "type": "string",
      "default": "manual",
      "enum": [
        "automatic",
        "manual",
        "disabled"
      ]
    },
    "model": {
      "title": "Codex model ID",
      "type": "string",
      "default": ""
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@inkdrop-codex/credential-contract": "workspace:*",
    "neverthrow": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@inkdropapp/types": "^0.0.9",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "vitest": "^4.1.10"
  }
}
